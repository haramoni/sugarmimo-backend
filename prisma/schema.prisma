// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                           String             @id @default(uuid()) @db.Char(36)
  username                     String             @unique(map: "username") @db.VarChar(50)
  email                        String             @unique(map: "email") @db.VarChar(255)
  passwordHash                 String             @map("password_hash") @db.Text
  role                         String?            @db.VarChar(30)
  gender                       String?            @db.VarChar(30)
  lookingFor                   String?            @map("looking_for") @db.VarChar(30)
  birthDate                    DateTime?          @map("birth_date") @db.Date
  country                      String?            @db.VarChar(80)
  state                        String?            @db.VarChar(80)
  city                         String?            @db.VarChar(80)
  whatsapp                     String?            @db.VarChar(30)
  telegram                     String?            @db.VarChar(80)
  instagram                    String?            @db.VarChar(80)
  approvalStatus               String             @default("PENDING") @map("approval_status") @db.VarChar(30)
  isPremium                    Boolean            @default(false) @map("is_premium")
  boostedUntil                 DateTime?          @map("boosted_until") @db.Timestamp(0)
  reviewedAt                   DateTime?          @map("reviewed_at") @db.Timestamp(0)
  lastActiveAt                 DateTime?          @map("last_active_at") @db.Timestamp(0)
  createdAt                    DateTime?          @default(now()) @map("created_at") @db.Timestamp(0)
  appearance                   UserAppearance?
  preferences                  UserPreference?
  photos                       UserPhoto[]
  activityLogs                 ActivityLog[]
  chatConversationsAsMemberOne ChatConversation[] @relation("ChatMemberOne")
  chatConversationsAsMemberTwo ChatConversation[] @relation("ChatMemberTwo")
  sentChatMessages             ChatMessage[]      @relation("ChatMessageSender")
  likesAsDaddy                 ProfileLike[]      @relation("ProfileLikeDaddy")
  likesAsBaby                  ProfileLike[]      @relation("ProfileLikeBaby")
  receivedNotifications        Notification[]     @relation("NotificationRecipient")
  sentNotifications            Notification[]     @relation("NotificationActor")

  @@index([role, approvalStatus, boostedUntil], map: "users_active_boost_idx")
  @@map("users")
}

model ProfileLike {
  id                 String         @id @default(uuid()) @db.Char(36)
  daddyId            String         @map("daddy_id") @db.Char(36)
  babyId             String         @map("baby_id") @db.Char(36)
  daddyLikedAt       DateTime?      @map("daddy_liked_at") @db.Timestamp(0)
  babyLikedAt        DateTime?      @map("baby_liked_at") @db.Timestamp(0)
  contactsReleasedAt DateTime?      @map("contacts_released_at") @db.Timestamp(0)
  createdAt          DateTime?      @default(now()) @map("created_at") @db.Timestamp(0)
  daddy              User           @relation("ProfileLikeDaddy", fields: [daddyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "profile_likes_daddy_id_fkey")
  baby               User           @relation("ProfileLikeBaby", fields: [babyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "profile_likes_baby_id_fkey")
  notifications      Notification[]

  @@unique([daddyId, babyId], map: "profile_likes_daddy_baby_unique")
  @@index([babyId, createdAt], map: "profile_likes_baby_created_at_idx")
  @@map("profile_likes")
}

model Notification {
  id            String       @id @default(uuid()) @db.Char(36)
  recipientId   String       @map("recipient_id") @db.Char(36)
  actorId       String       @map("actor_id") @db.Char(36)
  profileLikeId String?      @map("profile_like_id") @db.Char(36)
  type          String       @db.VarChar(50)
  readAt        DateTime?    @map("read_at") @db.Timestamp(0)
  createdAt     DateTime?    @default(now()) @map("created_at") @db.Timestamp(0)
  recipient     User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_recipient_id_fkey")
  actor         User         @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_actor_id_fkey")
  profileLike   ProfileLike? @relation(fields: [profileLikeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_profile_like_id_fkey")

  @@index([recipientId, createdAt], map: "notifications_recipient_created_at_idx")
  @@index([profileLikeId], map: "notifications_profile_like_id_idx")
  @@map("notifications")
}

model ActivityLog {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String?   @map("user_id") @db.Char(36)
  action     String    @db.VarChar(80)
  method     String    @db.VarChar(10)
  path       String    @db.VarChar(255)
  statusCode Int?      @map("status_code")
  ip         String?   @db.VarChar(80)
  userAgent  String?   @map("user_agent") @db.VarChar(255)
  metadata   Json?
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "activity_logs_user_id_fkey")

  @@index([createdAt], map: "activity_logs_created_at_idx")
  @@index([userId, createdAt], map: "activity_logs_user_created_at_idx")
  @@map("activity_logs")
}

model ChatConversation {
  id          String        @id @default(uuid()) @db.Char(36)
  memberOneId String        @map("member_one_id") @db.Char(36)
  memberTwoId String        @map("member_two_id") @db.Char(36)
  createdAt   DateTime?     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  memberOne   User          @relation("ChatMemberOne", fields: [memberOneId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chat_conversations_member_one_id_fkey")
  memberTwo   User          @relation("ChatMemberTwo", fields: [memberTwoId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chat_conversations_member_two_id_fkey")
  messages    ChatMessage[]

  @@unique([memberOneId, memberTwoId], map: "chat_conversations_members_unique")
  @@index([memberTwoId], map: "chat_conversations_member_two_id_idx")
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid()) @db.Char(36)
  conversationId String           @map("conversation_id") @db.Char(36)
  senderId       String           @map("sender_id") @db.Char(36)
  body           String           @db.Text
  readAt         DateTime?        @map("read_at") @db.Timestamp(0)
  createdAt      DateTime?        @default(now()) @map("created_at") @db.Timestamp(0)
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chat_messages_conversation_id_fkey")
  sender         User             @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chat_messages_sender_id_fkey")

  @@index([conversationId, createdAt], map: "chat_messages_conversation_created_at_idx")
  @@index([senderId], map: "chat_messages_sender_id_idx")
  @@map("chat_messages")
}

model UserPhoto {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  dataUrl   String    @map("data_url") @db.LongText
  fileName  String?   @map("file_name") @db.VarChar(255)
  mimeType  String?   @map("mime_type") @db.VarChar(120)
  sortOrder Int       @default(1) @map("sort_order")
  isPrivate Boolean   @default(false) @map("is_private")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_photos_ibfk_1")

  @@index([userId], map: "user_id")
  @@index([userId, isPrivate, sortOrder], map: "user_photos_user_private_order_idx")
  @@map("user_photos")
}

model UserAppearance {
  id        String  @id @default(uuid()) @db.Char(36)
  userId    String  @unique(map: "user_id") @map("user_id") @db.Char(36)
  bodyType  String? @map("body_type") @db.VarChar(50)
  ethnicity String? @db.VarChar(80)
  hairColor String? @map("hair_color") @db.VarChar(50)
  eyeColor  String? @map("eye_color") @db.VarChar(50)
  heightCm  Int?    @map("height_cm")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_appearance_ibfk_1")

  @@map("user_appearance")
}

model UserPreference {
  id                 String    @id @default(uuid()) @db.Char(36)
  userId             String    @unique(map: "user_id") @map("user_id") @db.Char(36)
  preferences        Json?
  introductionPhrase String?   @map("introduction_phrase") @db.VarChar(255)
  aboutMe            String?   @map("about_me") @db.Text
  lookingFor         String?   @map("looking_for") @db.Text
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_preferences_ibfk_1")

  @@map("user_preferences")
}
